---
import Layout from "../layouts/Layout.astro";
import TitleBar from "./TitleBar.astro";
import NavBar from "./NavBar.astro";
import Toolbar from "./Toolbar.astro";
import Taskbar from "./Taskbar.astro";

interface Props {
    title?: string;
    /** Per-page description override for <meta> + Open Graph. Defaults to site.description. */
    description?: string;
    /** Per-page Open Graph image override (path under /public). Defaults to site.ogImage. */
    ogImage?: string;
    /** Extra keywords for site search to find this page (off-screen). */
    searchKeywords?: string;
    /** "page" gets the personal-site theme; "system" gets a flat Win98 control-panel look. */
    variant?: "page" | "system";
}

const {
    title = "Home",
    description,
    ogImage,
    searchKeywords,
    variant = "page",
} = Astro.props as Props;
---

<Layout title={title} description={description} ogImage={ogImage}>
    <main class="desktop">
        <section id="browser" class="browser-window">
            <TitleBar title={title} />
            <NavBar />
            <Toolbar />

            <div class="content-shell">
                <article class:list={["content", `content--${variant}`]} data-pagefind-body>
                    {searchKeywords && (
                        <span class="visually-hidden">{searchKeywords}</span>
                    )}
                    <slot />
                </article>
            </div>
        </section>

        <section id="closed-message" class="closed-message hidden">
            Browser closed. Click Start to reopen.
        </section>

        <Taskbar />
    </main>
</Layout>

<script>
    const browser = document.querySelector<HTMLElement>("#browser");
    const closedMessage = document.querySelector<HTMLElement>("#closed-message");
    const closeButton = document.querySelector<HTMLButtonElement>("#close-browser");
    const startButton = document.querySelector<HTMLButtonElement>("#start-button");

    const backButton = document.querySelector<HTMLButtonElement>("#back-button");
    const forwardButton = document.querySelector<HTMLButtonElement>("#forward-button");

    const urlForm = document.querySelector<HTMLFormElement>("#url-form");
    const pathInput = document.querySelector<HTMLInputElement>("#path-input");

    const searchForm = document.querySelector<HTMLFormElement>("#site-search-form");
    const searchInput = document.querySelector<HTMLInputElement>("#site-search-input");

closeButton?.addEventListener("click", () => {
        browser?.classList.add("hidden");
        closedMessage?.classList.remove("hidden");
    });

    startButton?.addEventListener("click", () => {
        browser?.classList.remove("hidden");
        closedMessage?.classList.add("hidden");
    });

    backButton?.addEventListener("click", () => history.back());
    forwardButton?.addEventListener("click", () => history.forward());

urlForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        if (!pathInput) return;

        const siteName = urlForm.dataset.siteName ?? "";
        let path = pathInput.value.trim();

        path = path.replace(/^https?:\/\//, "");
        if (siteName) {
            const escaped = siteName.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
            path = path.replace(new RegExp(`^${escaped}\\/?`), "");
        }

        if (path === "") {
            window.location.href = "/";
            return;
        }

        if (!path.startsWith("/")) path = "/" + path;
        window.location.href = path;
    });

    searchForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        const searchPath = searchForm.dataset.searchPath ?? "/search";
        const query = searchInput?.value.trim() ?? "";
        // Empty submit still navigates to the search page so visitors can use
        // the larger form there.
        window.location.href = query
            ? `${searchPath}?q=${encodeURIComponent(query)}`
            : searchPath;
    });
</script>

<style>
    /* Pin the desktop to the viewport so the browser window doesn't push
       the page taller. Internal scrolling lives inside .content. */
    .desktop {
        height: 100vh;
        overflow: hidden;
        padding: 28px 28px 62px;
        display: flex;
        justify-content: center;
        align-items: flex-start;
    }

    /* Locked to a 13" laptop width. Mobile/responsive rules can be added later.
       Fixed height (capped at 820px) so the window itself never grows; long
       content scrolls inside .content. */
    .browser-window {
        width: min(calc(100vw - 48px), 1280px);
        height: min(820px, calc(100vh - 110px));
        display: flex;
        flex-direction: column;
        background: #ece9d8;
        border: 2px solid #ffffff;
        border-right-color: #404040;
        border-bottom-color: #404040;
        box-shadow:
            1px 1px 0 #000,
            8px 8px 20px rgb(0 0 0 / 0.35);
    }

    /* flex: 1 so the white content area fills the rest of the window —
       prevents the beige browser-window background from peeking through below.
       min-height: 0 lets the flex child shrink so .content's overflow can scroll.
       Margin gives a Win98-style beige frame around the content; the sunken
       border completes the recessed-pane look. */
    .content-shell {
        flex: 1;
        min-height: 0;
        display: flex;
        margin: 0 3px 3px;
        background: white;
        border: 2px solid;
        border-top-color: #808080;
        border-left-color: #808080;
        border-right-color: #ffffff;
        border-bottom-color: #ffffff;
        overflow: hidden;
    }

    .content {
        flex: 1;
        padding: 34px 64px 60px;
        font-family: var(--page-body-font);
        font-size: 18px;
        line-height: 1.5;
        color: var(--page-text);
        /* Subtle graph-paper grid + warm cream base. Replace with a tile image
           via --page-bg if you want a more personal background. */
        background-color: var(--page-bg);
        background-image:
            repeating-linear-gradient(0deg, transparent 0 19px, rgba(0, 0, 0, 0.05) 19px 20px),
            repeating-linear-gradient(90deg, transparent 0 19px, rgba(0, 0, 0, 0.05) 19px 20px);
        overflow-y: auto;
        /* Firefox: thin retro-tinted scrollbar (no buttons available). */
        scrollbar-color: #d4d0c8 #ece9d8;
    }

    .content :global(a) {
        color: var(--page-link);
        text-decoration: underline;
    }

    .content :global(a:visited) {
        color: var(--page-link-visited);
    }

    .content :global(a:hover),
    .content :global(a:focus-visible) {
        background: var(--page-highlight);
    }

    .content :global(a:focus-visible) {
        outline: 2px solid var(--page-accent);
        outline-offset: 2px;
    }

    .content :global(h2) {
        font-family: var(--page-heading-font);
        font-size: 28px;
        margin: 32px 0 14px;
        padding-bottom: 4px;
        border-bottom: 3px solid var(--page-accent);
        display: inline-block;
    }

    .content :global(p) {
        margin: 0 0 14px;
    }

    .content :global(h3) {
        font-family: var(--page-heading-font);
        font-size: 22px;
        margin: 24px 0 10px;
    }

    .content :global(code) {
        padding: 1px 5px;
        background: var(--page-accent-soft);
        border: 1px solid var(--page-accent);
        font-family: "Courier New", Courier, monospace;
        font-size: 0.95em;
    }

    /* === Reusable content components ===
       Use these classes on any page that opts into variant="page". The home
       page composes .sticker into a grid; the Theme & Style Guide page
       demonstrates them standalone. Style overrides per page are still fine. */

    /* Sticker — chunky white card with magenta drop shadow. */
    .content :global(.sticker) {
        display: grid;
        grid-template-columns: 56px 1fr;
        grid-template-rows: auto auto;
        column-gap: 14px;
        row-gap: 4px;
        align-items: center;
        padding: 14px 18px;
        background: #ffffff;
        color: var(--page-text);
        text-decoration: none;
        border: 3px solid var(--page-text);
        box-shadow: 5px 5px 0 var(--page-accent);
        transition: transform 0.08s ease-out;
    }

    .content :global(.sticker:hover),
    .content :global(.sticker:focus-visible) {
        background: var(--page-highlight);
        transform: scale(1.02);
    }

    .content :global(.sticker:focus-visible) {
        outline: 3px solid var(--page-accent);
        outline-offset: 4px;
    }

    .content :global(.sticker:active) {
        transform: translate(3px, 3px);
        box-shadow: 2px 2px 0 var(--page-accent);
    }

    .content :global(.sticker-icon) {
        grid-row: 1 / span 2;
        width: 48px;
        height: 48px;
        image-rendering: pixelated;
        object-fit: contain;
    }

    .content :global(.sticker-label) {
        font-family: var(--page-heading-font);
        font-size: 22px;
        font-weight: bold;
    }

    .content :global(.sticker-blurb) {
        font-size: 15px;
        color: var(--page-muted);
    }

    /* News — soft-pink callout box with a rotated NEW! badge. */
    .content :global(.news) {
        position: relative;
        padding: 18px 24px 14px;
        background: var(--page-accent-soft);
        border: 3px solid var(--page-text);
        box-shadow: 5px 5px 0 var(--page-accent);
    }

    .content :global(.news-badge) {
        position: absolute;
        top: -18px;
        left: -14px;
        padding: 4px 10px;
        font-family: var(--page-heading-font);
        font-weight: bold;
        font-size: 18px;
        color: white;
        background: var(--page-accent);
        border: 2px solid var(--page-text);
        transform: rotate(-8deg);
        box-shadow: 2px 2px 0 var(--page-text);
    }

    .content :global(.news-list) {
        list-style: none;
        padding: 0;
        margin: 6px 0 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .content :global(.news-list li) {
        display: flex;
        gap: 10px;
        font-size: 16px;
    }

    .content :global(.news-date) {
        flex: 0 0 80px;
        font-weight: bold;
        color: var(--page-accent);
    }

    /* WebKit/Chromium: retro scrollbar with up/down buttons, hatched track,
       and a raised thumb. Firefox ignores these and falls back to
       scrollbar-color above. */
    .content::-webkit-scrollbar {
        width: 31px;
    }

    .content::-webkit-scrollbar-track {
        background-color: #ece9d8;
        background-image:
            linear-gradient(45deg, #d4d0c8 25%, transparent 25%, transparent 75%, #d4d0c8 75%),
            linear-gradient(45deg, #d4d0c8 25%, transparent 25%, transparent 75%, #d4d0c8 75%);
        background-size: 4px 4px;
        background-position: 0 0, 2px 2px;
        border-left: 1px solid #111;
    }

    .content::-webkit-scrollbar-thumb {
        background: #d4d0c8;
        border: 2px solid;
        border-top-color: #ffffff;
        border-left-color: #ffffff;
        border-right-color: #555555;
        border-bottom-color: #555555;
    }

    .content::-webkit-scrollbar-button {
        display: block;
        height: 30px;
        background: #ece9d8;
        border: 2px solid;
        border-top-color: #ffffff;
        border-left-color: #ffffff;
        border-right-color: #333333;
        border-bottom-color: #333333;
        background-repeat: no-repeat;
        background-position: center;
    }

    .content::-webkit-scrollbar-button:vertical:decrement {
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 10 10'><polygon points='5,3 8,7 2,7' fill='black'/></svg>");
    }

    .content::-webkit-scrollbar-button:vertical:increment {
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 10 10'><polygon points='2,3 8,3 5,7' fill='black'/></svg>");
    }

    /* Hide the secondary buttons WebKit adds at the opposite ends. */
    .content::-webkit-scrollbar-button:vertical:start:increment,
    .content::-webkit-scrollbar-button:vertical:end:decrement {
        display: none;
    }

    /* === System variant ===
       Used by pages that should read as Win98 control-panel applets rather
       than personal-site content. Plain page bg, no graph paper, plain Tahoma
       type. Wrap form/applet content in <div class="system-pane"> for the
       bounded gray Win98 box. */
    .content--system {
        background-color: var(--page-bg);
        background-image: none;
        font-family: Tahoma, Verdana, sans-serif;
        font-size: 16px;
        color: #111;
    }

    /* Bounded applet pane — sits on top of the page background like a control
       panel window. Use class="system-pane" on a wrapper div. */
    .content :global(.system-pane) {
        max-width: 640px;
        margin: 16px 0 24px;
        padding: 20px 24px;
        background: #c0c0c0;
        border: 2px solid #ffffff;
        border-right-color: #404040;
        border-bottom-color: #404040;
        box-shadow: inset 1px 1px 0 #ffffff, 1px 1px 0 #000;
    }

    .content.content--system :global(h1) {
        display: block;
        margin: 0 0 14px;
        padding: 4px 0 6px;
        font-family: Tahoma, Verdana, sans-serif;
        font-size: 22px;
        font-weight: bold;
        color: #111;
        background: transparent;
        border: 0;
        border-bottom: 2px solid #888;
        box-shadow: none;
    }

    .content.content--system :global(h2) {
        display: block;
        margin: 18px 0 8px;
        padding: 0;
        font-family: Tahoma, Verdana, sans-serif;
        font-size: 17px;
        font-weight: bold;
        border: 0;
    }

    .content.content--system :global(a) {
        color: #0000ee;
    }
    .content.content--system :global(a:visited) {
        color: #551a8b;
    }
    .content.content--system :global(a:hover) {
        background: transparent;
        text-decoration: underline;
    }

    .content.content--system :global(code) {
        background: transparent;
        border: 0;
        padding: 0;
    }

    /* Big serif headline with a chunky accent underline + offset shadow.
       Replaces the previous boxed-out look. */
    .content :global(h1) {
        display: inline-block;
        margin: 0 0 28px;
        padding: 6px 4px;
        font-family: var(--page-heading-font);
        font-size: 44px;
        font-weight: normal;
        line-height: 1.1;
        color: var(--page-text);
        background: var(--page-highlight);
        box-shadow: 5px 5px 0 var(--page-accent);
        border: 2px solid var(--page-text);
        padding: 8px 20px;
    }

    .closed-message {
        color: white;
        font-size: 1.5rem;
        text-shadow: 2px 2px #000;
    }

    .hidden {
        display: none;
    }

    /* Off-screen but still in the DOM — Pagefind reads it, users don't see it. */
    .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }
</style>
