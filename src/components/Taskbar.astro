<footer class="taskbar">
    <button id="start-button">Start</button>
</footer>

<style>
    .taskbar {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        height: 44px;
        display: flex;
        align-items: center;
        padding: 4px;
        background: #d4d0c8;
        border-top: 2px solid #fff;
        box-shadow: inset 0 1px #fff;
    }

    #start-button {
        min-width: 126px;
        height: 36px;
        font: 20px Tahoma, sans-serif;
        background: #ece9d8;
        border: 2px solid #fff;
        border-right-color: #111;
        border-bottom-color: #111;
        cursor: pointer;
    }
</style>
