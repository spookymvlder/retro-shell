---
import { site } from "../site.config";
---

<footer class="taskbar">
    <button id="start-button">Start</button>
    {site.clock.enabled && (
        <div
            id="taskbar-clock"
            class="clock"
            data-default-tz={site.clock.defaultTimezone}
            data-default-format={site.clock.defaultFormat}
        >
            --:--
        </div>
    )}
</footer>

<script>
    import { loadSettings } from "../lib/userSettings";

    const clock = document.querySelector<HTMLElement>("#taskbar-clock");
    if (clock) {
        const defaultTz = clock.dataset.defaultTz ?? "UTC";
        const defaultFormat = (clock.dataset.defaultFormat ?? "12h") as "12h" | "24h";

        function tick() {
            const settings = loadSettings();
            const tz = settings.timezone ?? defaultTz;
            const format = settings.clockFormat ?? defaultFormat;
            try {
                clock!.textContent = new Intl.DateTimeFormat("en-US", {
                    timeZone: tz,
                    hour: "numeric",
                    minute: "2-digit",
                    hour12: format === "12h",
                }).format(new Date());
            } catch {
                clock!.textContent = "??:??";
            }
        }

        tick();
        // Align the next tick to the top of the next minute, then every 60s after.
        const msUntilNextMinute = 60000 - (Date.now() % 60000);
        setTimeout(() => {
            tick();
            setInterval(tick, 60000);
        }, msUntilNextMinute);
    }
</script>

<style>
    .taskbar {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 4px 6px;
        background: #d4d0c8;
        border-top: 2px solid #fff;
        box-shadow: inset 0 1px #fff;
    }

    #start-button {
        min-width: 126px;
        height: 36px;
        font: 20px Tahoma, sans-serif;
        background: #ece9d8;
        border: 2px solid #fff;
        border-right-color: #111;
        border-bottom-color: #111;
        cursor: pointer;
    }

    #start-button:focus-visible {
        outline: 2px dotted #000;
        outline-offset: -5px;
    }

    @media (max-width: 890px) {
        .taskbar {
            display: none;
        }
    }

    /* Win98 system-tray clock: double-bevel sunken box on the right edge.
       Outer border + inner box-shadow gives the classic 2-tone inset look. */
    .clock {
        min-width: 88px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 12px;
        font: 16px Tahoma, sans-serif;
        background: #d4d0c8;
        border: 1px solid;
        border-top-color: #808080;
        border-left-color: #808080;
        border-right-color: #ffffff;
        border-bottom-color: #ffffff;
        box-shadow:
            inset 1px 1px 0 0 #404040,
            inset -1px -1px 0 0 #d4d0c8;
    }
</style>
