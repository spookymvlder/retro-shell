---
import { site } from "../site.config";

const currentPath = Astro.url.pathname;
const normalize = (p: string) => (p.endsWith("/") && p !== "/" ? p.slice(0, -1) : p);
const here = normalize(currentPath);
---

{site.sidebarNav.enabled && (
    <nav class="sidebar" aria-label="Site navigation">
        {site.sidebarNav.heading && (
            <h2 class="sidebar-heading">{site.sidebarNav.heading}</h2>
        )}
        <ul class="sidebar-list">
            {site.sidebarNav.links.map((link) => {
                const target = normalize(link.href);
                const active = target === here;
                return (
                    <li>
                        <a
                            href={link.href}
                            class:list={["sidebar-link", { "sidebar-link--active": active }]}
                            aria-current={active ? "page" : undefined}
                        >
                            {link.label}
                        </a>
                    </li>
                );
            })}
        </ul>
    </nav>
)}

<style>
    .sidebar {
        padding: 12px 14px;
        background: #ffffff;
        border: 2px solid var(--page-text);
        box-shadow: 4px 4px 0 var(--page-accent);
    }

    .sidebar-heading {
        margin: 0 0 10px;
        padding: 0 0 6px;
        font-family: var(--page-heading-font);
        font-size: 18px;
        font-weight: bold;
        border-bottom: 2px solid var(--page-accent);
    }

    .sidebar-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .sidebar-link {
        display: block;
        padding: 6px 10px;
        font-family: var(--page-body-font);
        font-size: 16px;
        color: var(--page-link);
        text-decoration: none;
        border: 1px solid transparent;
    }

    .sidebar-link:hover,
    .sidebar-link:focus-visible {
        background: var(--page-highlight);
        color: var(--page-text-on-highlight);
        outline: 0;
        border-color: var(--page-text);
    }

    .sidebar-link--active {
        background: var(--page-accent-soft);
        border-color: var(--page-accent);
        font-weight: bold;
    }
</style>
