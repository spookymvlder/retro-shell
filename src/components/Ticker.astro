---
import { site } from "../site.config";
---

<div
    class="ticker"
    data-refresh-seconds={site.ticker.refreshSeconds}
    aria-label="Stock ticker"
>
    <div class="ticker-track" id="ticker-track">
        <span class="ticker-loading">Loading market data…</span>
    </div>
</div>

<script>
    interface TickerEntry {
        symbol: string;
        label: string;
        price: number;
        change: number;
        changePercent: number;
    }

    interface TickerResponse {
        entries: TickerEntry[];
    }

    const ticker = document.querySelector<HTMLElement>(".ticker");
    const track = document.querySelector<HTMLElement>("#ticker-track");
    if (ticker && track) {
        const refreshMs = (Number(ticker.dataset.refreshSeconds) || 300) * 1000;

        function formatEntry(e: TickerEntry): string {
            const arrow = e.change > 0 ? "▲" : e.change < 0 ? "▼" : "■";
            const sign = e.change > 0 ? "+" : "";
            const cls = e.change > 0 ? "up" : e.change < 0 ? "down" : "flat";
            return `<span class="entry ${cls}"><span class="sym">${e.label}</span> <span class="price">${e.price.toFixed(2)}</span> <span class="arrow">${arrow}</span> <span class="chg">${sign}${e.changePercent.toFixed(2)}%</span></span>`;
        }

        async function load() {
            try {
                const res = await fetch("/api/ticker");
                const data = (await res.json()) as TickerResponse;
                if (!data.entries.length) {
                    track!.innerHTML = `<span class="ticker-loading">Market data unavailable.</span>`;
                    return;
                }
                // Build the strip twice so the marquee animation can loop seamlessly.
                const html = data.entries.map(formatEntry).join("");
                track!.innerHTML = html + html;
            } catch {
                track!.innerHTML = `<span class="ticker-loading">Market data unavailable.</span>`;
            }
        }

        load();
        setInterval(load, refreshMs);
    }
</script>

<style>
    .ticker {
        position: relative;
        height: 26px;
        background: #000000;
        border-top: 1px solid #404040;
        border-bottom: 1px solid #888888;
        overflow: hidden;
        font: 14px "Courier New", Courier, monospace;
        color: #ffd21a;
    }

    /* Two copies of the entries side-by-side; we translate the whole track
       by -50% so the second copy slides into place where the first started. */
    .ticker-track {
        display: flex;
        gap: 36px;
        align-items: center;
        height: 100%;
        padding-left: 18px;
        white-space: nowrap;
        will-change: transform;
        animation: ticker-scroll 80s linear infinite;
    }

    .ticker:hover .ticker-track {
        animation-play-state: paused;
    }

    @keyframes ticker-scroll {
        from { transform: translateX(0); }
        to { transform: translateX(-50%); }
    }

    .ticker :global(.entry) {
        display: inline-flex;
        gap: 6px;
        align-items: baseline;
    }

    .ticker :global(.sym) {
        font-weight: bold;
        color: #ffffff;
    }

    .ticker :global(.up) :global(.arrow),
    .ticker :global(.up) :global(.chg) {
        color: #00d060;
    }

    .ticker :global(.down) :global(.arrow),
    .ticker :global(.down) :global(.chg) {
        color: #ff5050;
    }

    .ticker :global(.flat) :global(.arrow),
    .ticker :global(.flat) :global(.chg) {
        color: #aaaaaa;
    }

    .ticker-loading {
        opacity: 0.7;
    }
</style>
