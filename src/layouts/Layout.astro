---
import { site } from "../site.config";

interface Props {
    title?: string;
}

const { title = "Home" } = Astro.props as Props;
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | {site.titleSuffix}</title>
</head>
<body>
<slot />
</body>
</html>

<style is:global>
    * {
        box-sizing: border-box;
    }

    html,
    body {
        margin: 0;
    }

    /* Page-content theme tokens. The shell chrome (title bar, toolbar, taskbar)
       intentionally ignores these and stays Win98-y; the page area inside
       the browser is where personal-site personality lives. */
    :root {
        --page-bg: #fff5e8;
        --page-text: #2a1a0a;
        --page-muted: #6a4a2a;
        --page-accent: #c43e7a;
        --page-accent-soft: #ffe0ed;
        --page-highlight: #ffd21a;
        --page-link: #1a3aea;
        --page-link-visited: #6a26a4;
        --page-heading-font: Georgia, "Times New Roman", serif;
        --page-body-font: Verdana, Tahoma, sans-serif;
    }

    body {
        font-family: Tahoma, Verdana, sans-serif;
        background: #0b7180;
        color: #111;
    }
</style>
