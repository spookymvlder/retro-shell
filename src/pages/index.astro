---
import RetroShell from "../components/RetroShell.astro";

export const prerender = true;

interface DirectoryLink {
    href: string;
    label: string;
    icon: string;
    description: string;
}

const directory: DirectoryLink[] = [
    { href: "/projects", label: "Projects", icon: "folder", description: "Things I've made." },
    { href: "/guestbook", label: "Guestbook", icon: "guestbook", description: "Sign the book!" },
    { href: "/about", label: "About", icon: "info", description: "Who runs this site." },
    { href: "/contact", label: "Contact", icon: "mail", description: "Drop me a line." },
];
---

<RetroShell
    title="Home"
    searchKeywords="welcome home main directory weather clock guestbook projects contact about template"
>
    <h1>Welcome to Retro Shell</h1>

    <p>
        This is a template for building a personal website wrapped in a fake
        late-90s / early-2000s browser window. Replace this content with your own,
        update <code>src/site.config.ts</code> with your links, and you're off.
    </p>

    <h2>Real Site Directory</h2>

    <ul class="directory">
        {directory.map((entry) => (
            <li>
                <a class="directory-tile" href={entry.href}>
                    <img
                        class="directory-icon"
                        src={`/icons/${entry.icon}.png`}
                        alt=""
                        loading="lazy"
                    />
                    <span class="directory-label">{entry.label}</span>
                    <span class="directory-description">{entry.description}</span>
                </a>
            </li>
        ))}
    </ul>

    <h2>Make it your own</h2>

    <p>
        Edit <code>src/site.config.ts</code> to change the site name, toolbar
        buttons, default time zone, and weather location. Drop new pages into
        <code>src/pages/</code> and wrap them in <code>&lt;RetroShell&gt;</code>.
        See the <a href="https://github.com/spookymvlder/retro-shell">project README</a>
        for the full setup walkthrough — including the optional Cloudflare D1
        guestbook and Turnstile spam protection.
    </p>

    <p>
        Don't like a piece of the chrome? Toolbar buttons, the weather widget,
        the search box, the guestbook, and the taskbar clock can each be toggled
        individually in the config.
    </p>
    <p>
        Don't like a piece of the chrome? Toolbar buttons, the weather widget,
        the search box, the guestbook, and the taskbar clock can each be toggled
        individually in the config.
    </p>
    <p>
        Don't like a piece of the chrome? Toolbar buttons, the weather widget,
        the search box, the guestbook, and the taskbar clock can each be toggled
        individually in the config.
    </p>
    <p>
        Don't like a piece of the chrome? Toolbar buttons, the weather widget,
        the search box, the guestbook, and the taskbar clock can each be toggled
        individually in the config.
    </p>
    <p>
        Don't like a piece of the chrome? Toolbar buttons, the weather widget,
        the search box, the guestbook, and the taskbar clock can each be toggled
        individually in the config.
    </p>
    <p>
        Don't like a piece of the chrome? Toolbar buttons, the weather widget,
        the search box, the guestbook, and the taskbar clock can each be toggled
        individually in the config.
    </p>
</RetroShell>

<style>
    .directory {
        list-style: none;
        padding: 0;
        margin: 0 0 32px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
        max-width: 720px;
    }

    .directory-tile {
        display: grid;
        grid-template-columns: 64px 1fr;
        grid-template-rows: auto auto;
        column-gap: 14px;
        row-gap: 4px;
        align-items: center;
        padding: 14px 16px;
        color: #111;
        text-decoration: none;
        background: #ece9d8;
        border: 2px solid #fff;
        border-right-color: #555;
        border-bottom-color: #555;
    }

    .directory-tile:hover {
        background: #fffff0;
        outline: 1px dotted #111;
    }

    .directory-tile:active {
        border: 2px inset #d4d0c8;
    }

    .directory-icon {
        grid-row: 1 / span 2;
        width: 48px;
        height: 48px;
        image-rendering: pixelated;
        object-fit: contain;
    }

    .directory-label {
        font-size: 22px;
        font-weight: bold;
    }

    .directory-description {
        font-size: 16px;
        color: #444;
    }

    code {
        padding: 1px 5px;
        background: #fffff0;
        border: 1px solid #aaa;
        font-family: "Courier New", Courier, monospace;
        font-size: 0.95em;
    }
</style>
