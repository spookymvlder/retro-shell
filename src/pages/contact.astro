---
import RetroShell from "../components/RetroShell.astro";

export const prerender = true;
---

<RetroShell
    title="Contact"
    description="Ways to get in touch."
    searchKeywords="contact email reach social mailto"
>
    <h1>Contact</h1>

    <p class="lede">
        Replace this page with your real contact info.
    </p>

    <ul class="contact-list">
        <li>
            <strong>Email:</strong>
            <a href="mailto:you@example.com">you@example.com</a>
        </li>
        <li>
            <strong>GitHub:</strong>
            <a href="https://github.com/YOUR_USERNAME">@YOUR_USERNAME</a>
        </li>
        <li>
            <strong>Guestbook:</strong>
            <a href="/guestbook">Sign the book</a>
        </li>
    </ul>

    <p>
        Edit <code>src/pages/contact.astro</code> to update these links.
    </p>
</RetroShell>

<style>
    .lede {
        font-size: 19px;
        max-width: 60ch;
    }

    .contact-list {
        list-style: none;
        padding: 0;
        margin: 16px 0 24px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        font-size: 17px;
    }

    .contact-list strong {
        display: inline-block;
        min-width: 90px;
    }
</style>
