---
import RetroShell from "../components/RetroShell.astro";

export const prerender = true;

interface ContactLink {
    href: string;
    label: string;
    icon: string;
    blurb: string;
    external: boolean,
}

const contact: ContactLink[] = [
    { href: "mailto:you@example.com", external: true, label: "Email", icon: "mail", blurb: "you@example.com" },
    { href: "https://github.com/YOUR_USERNAME", external: true, label: "GitHub", icon: "github", blurb: "@YOUR_USERNAME" },
    { href: "/guestbook", external: false, label: "Guestbook", icon: "guestbook", blurb: "Sign in!" },
];
---

<RetroShell
    title="Contact"
    description="Ways to get in touch."
    searchKeywords="contact email reach social mailto"
>
    <div class="card">
        <p class="lede">
            Replace this page with your real contact info.
        </p>

        <ul class="contact">
            {contact.map((entry) => (
                    <li>
                        <a class="sticker" href={entry.href}>
                            <img
                                    class="sticker-icon"
                                    src={`/icons/${entry.icon}.png`}
                                    alt=""
                                    loading="lazy"
                            />
                            <span class="sticker-label">{entry.label}</span>
                            <span class="sticker-blurb">{entry.blurb}</span>
                        </a>
                    </li>
            ))}
        </ul>

        <p>
            Edit <code>src/pages/contact.astro</code> to update these links.
        </p>
    </div>


</RetroShell>

<style>
    .lede {
        font-size: 19px;
        max-width: 60ch;
    }

    .contact {
        list-style: none;
        padding: 0;
        margin: 8px 0 36px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 22px 18px;
    }

    .contact li:nth-child(odd) :global(.sticker) {
        transform: rotate(-1.2deg);
    }
    .contact li:nth-child(even) :global(.sticker) {
        transform: rotate(1deg);
    }
</style>
