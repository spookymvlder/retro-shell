---
import RetroShell from "../components/RetroShell.astro";
import { site } from "../site.config";

export const prerender = true;
---

<RetroShell
    title="Settings"
    variant="system"
    searchKeywords="weather forecast temperature zip code time zone clock 12-hour 24-hour preferences"
>
    <div class="system-pane settings-dialog">
        <div class="dialog-titlebar">System Settings</div>

        <form id="settings-form" class="dialog-body">
            <div class="tab-strip">
                <span class="tab tab--active">Display</span>
            </div>

            <div class="tab-pane">
                <fieldset class="groove">
                    <legend>Weather</legend>
                    <div class="form-row">
                        <label for="zip">Zip code:</label>
                        <input
                            id="zip"
                            name="zip"
                            inputmode="numeric"
                            pattern="[0-9]{5}"
                            maxlength="5"
                            placeholder="e.g. 98402"
                        />
                    </div>
                    <p class="hint">Leave blank to use the site default.</p>
                </fieldset>

                <fieldset class="groove">
                    <legend>Clock</legend>
                    <div class="form-row">
                        <label for="timezone">Time zone:</label>
                        <select id="timezone" name="timezone">
                            <option value="">Site default ({site.clock.defaultTimezone})</option>
                            {site.clock.timezoneOptions.map((opt) => (
                                <option value={opt.value}>{opt.label}</option>
                            ))}
                        </select>
                    </div>
                    <div class="form-row">
                        <label for="clock-format">Format:</label>
                        <select id="clock-format" name="clockFormat">
                            <option value="">Site default ({site.clock.defaultFormat})</option>
                            <option value="12h">12-hour (1:30 PM)</option>
                            <option value="24h">24-hour (13:30)</option>
                        </select>
                    </div>
                </fieldset>
            </div>

            <div class="dialog-actions">
                <button type="submit">Save</button>
                <button type="button" id="reset-button">Reset to defaults</button>
            </div>
        </form>
    </div>
</RetroShell>

<script>
    import { loadSettings, saveSettings, clearSettings } from "../lib/userSettings";

    const form = document.querySelector<HTMLFormElement>("#settings-form");
    const zip = document.querySelector<HTMLInputElement>("#zip");
    const tz = document.querySelector<HTMLSelectElement>("#timezone");
    const fmt = document.querySelector<HTMLSelectElement>("#clock-format");
    const resetBtn = document.querySelector<HTMLButtonElement>("#reset-button");

    // Pre-fill from existing settings.
    const current = loadSettings();
    if (zip) zip.value = current.zip ?? "";
    if (tz) tz.value = current.timezone ?? "";
    if (fmt) fmt.value = current.clockFormat ?? "";

    form?.addEventListener("submit", (event) => {
        event.preventDefault();
        const next = {
            zip: zip?.value.trim() || undefined,
            timezone: tz?.value || undefined,
            clockFormat: (fmt?.value || undefined) as "12h" | "24h" | undefined,
        };
        saveSettings(next);
        location.reload();
    });

    resetBtn?.addEventListener("click", () => {
        clearSettings();
        location.reload();
    });
</script>

<style>
    .settings-dialog {
        max-width: 560px;
        margin-left: auto;
        margin-right: auto;
        padding: 0; /* dialog-body provides its own padding */
    }

    /* Inner blue gradient title bar — matches the browser title bar style. */
    .dialog-titlebar {
        padding: 5px 10px;
        font: bold 14px Tahoma, sans-serif;
        color: #ffffff;
        background: linear-gradient(90deg, #000080, #0a65c0);
    }

    .dialog-body {
        padding: 12px 14px 10px;
    }

    /* Win98 tab strip — folder-tab look. The active tab merges with the
       tab-pane below by overlapping the shared border by 1px. */
    .tab-strip {
        display: flex;
        gap: 0;
        padding-left: 8px;
        position: relative;
        z-index: 1;
    }

    .tab {
        padding: 4px 14px;
        font: 14px Tahoma, sans-serif;
        background: #c0c0c0;
        border: 1px solid #888;
        border-bottom: 0;
        border-radius: 4px 4px 0 0;
        margin-bottom: -1px;
        cursor: default;
    }

    .tab--active {
        background: #c0c0c0;
        padding-bottom: 5px; /* nudges active tab down to overlap pane border */
    }

    /* Inner pane that holds the tab content. The 1px border meets the
       active tab's bottom edge cleanly. */
    .tab-pane {
        padding: 12px 12px 16px;
        border: 1px solid #888;
        background: #c0c0c0;
    }

    /* Etched single-line groove for fieldsets. Two-tone borders simulate
       the Win98 inset look without using border-style: groove (which renders
       inconsistently across browsers). */
    .groove {
        margin: 0 0 14px;
        padding: 6px 14px 12px;
        border: 1px solid;
        border-top-color: #808080;
        border-left-color: #808080;
        border-right-color: #ffffff;
        border-bottom-color: #ffffff;
        background: transparent;
    }

    .groove legend {
        padding: 0 4px;
        font: 14px Tahoma, sans-serif;
    }

    .form-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 6px 0;
    }

    .form-row label {
        flex: 0 0 100px;
        font: 14px Tahoma, sans-serif;
    }

    .form-row input,
    .form-row select {
        flex: 1;
        max-width: 240px;
        height: 24px;
        padding: 2px 6px;
        font: 14px Tahoma, sans-serif;
        background: #ffffff;
        border: 2px solid;
        border-top-color: #808080;
        border-left-color: #808080;
        border-right-color: #ffffff;
        border-bottom-color: #ffffff;
    }

    .hint {
        margin: 6px 0 0 110px;
        font-size: 12px;
        color: #555;
    }

    /* Action bar with right-aligned buttons and a thin top divider. */
    .dialog-actions {
        display: flex;
        justify-content: flex-end;
        gap: 6px;
        margin-top: 14px;
        padding-top: 12px;
        border-top: 1px solid #888;
    }

    .dialog-actions button {
        min-width: 84px;
        height: 26px;
        padding: 0 12px;
        font: 14px Tahoma, sans-serif;
        background: #c0c0c0;
        border: 2px solid #ffffff;
        border-right-color: #404040;
        border-bottom-color: #404040;
        cursor: pointer;
    }

    .dialog-actions button:active {
        border: 2px solid #404040;
        border-right-color: #ffffff;
        border-bottom-color: #ffffff;
    }
</style>
