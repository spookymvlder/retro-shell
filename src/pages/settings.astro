---
import RetroShell from "../components/RetroShell.astro";
import { site } from "../site.config";

export const prerender = true;
---

<RetroShell
    title="Settings"
    variant="system"
    searchKeywords="weather forecast temperature zip code time zone clock 12-hour 24-hour preferences"
>
    <div class="settings-dialog">
        <div class="dialog-titlebar">
            <span class="dialog-titlebar-text">System Settings</span>
            <a href="/" class="dialog-close" aria-label="Close (return home)">X</a>
        </div>

        <form id="settings-form" class="dialog-body">
            <div class="tab-strip" role="tablist">
                <button
                    type="button"
                    class="tab tab--active"
                    role="tab"
                    data-tab="display"
                    aria-selected="true"
                    aria-controls="tab-display"
                >Display</button>
                <button
                    type="button"
                    class="tab"
                    role="tab"
                    data-tab="theme"
                    aria-selected="false"
                    aria-controls="tab-theme"
                >Appearance</button>
            </div>

            <div class="tab-pane" id="tab-display" data-tabpane="display" role="tabpanel">
                <fieldset class="groove">
                    <legend>Weather</legend>
                    <div class="form-row">
                        <label for="zip">Zip code:</label>
                        <input
                            id="zip"
                            name="zip"
                            inputmode="numeric"
                            pattern="[0-9]{5}"
                            maxlength="5"
                            placeholder="e.g. 98402"
                        />
                    </div>
                    <p class="hint">Leave blank to use the site default.</p>
                </fieldset>

                <fieldset class="groove">
                    <legend>Clock</legend>
                    <div class="form-row">
                        <label for="timezone">Time zone:</label>
                        <span class="select-wrap">
                            <select id="timezone" name="timezone">
                                <option value="">Site default ({site.clock.defaultTimezone})</option>
                                {site.clock.timezoneOptions.map((opt) => (
                                    <option value={opt.value}>{opt.label}</option>
                                ))}
                            </select>
                        </span>
                    </div>
                    <div class="form-row">
                        <label for="clock-format">Format:</label>
                        <span class="select-wrap">
                            <select id="clock-format" name="clockFormat">
                                <option value="">Site default ({site.clock.defaultFormat})</option>
                                <option value="12h">12-hour (1:30 PM)</option>
                                <option value="24h">24-hour (13:30)</option>
                            </select>
                        </span>
                    </div>
                </fieldset>
            </div>

            <div class="tab-pane" id="tab-theme" data-tabpane="theme" role="tabpanel" hidden>
                <fieldset class="groove">
                    <legend>Theme</legend>
                    <div class="form-row">
                        <label for="theme">Color scheme:</label>
                        <span class="select-wrap">
                            <select id="theme" name="theme">
                                <option value="">Site default ({site.darkMode.default})</option>
                                <option value="light">Light</option>
                                <option value="dark">Dark</option>
                            </select>
                        </span>
                    </div>
                    <p class="hint">The toolbar sun/moon button toggles between light and dark — use this to clear that override.</p>
                </fieldset>
            </div>

            <div class="dialog-actions">
                <button type="submit">Save</button>
                <button type="button" id="reset-button">Reset to defaults</button>
            </div>
        </form>
    </div>
</RetroShell>

<script>
    import { loadSettings, saveSettings, clearSettings } from "../lib/userSettings";

    const form = document.querySelector<HTMLFormElement>("#settings-form");
    const zip = document.querySelector<HTMLInputElement>("#zip");
    const tz = document.querySelector<HTMLSelectElement>("#timezone");
    const fmt = document.querySelector<HTMLSelectElement>("#clock-format");
    const themeSelect = document.querySelector<HTMLSelectElement>("#theme");
    const resetBtn = document.querySelector<HTMLButtonElement>("#reset-button");

    // Tab switching: clicking a tab shows its matching pane and hides the rest.
    const tabs = document.querySelectorAll<HTMLButtonElement>(".tab");
    const panes = document.querySelectorAll<HTMLElement>(".tab-pane");
    tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
            const target = tab.dataset.tab;
            tabs.forEach((t) => {
                const active = t === tab;
                t.classList.toggle("tab--active", active);
                t.setAttribute("aria-selected", active ? "true" : "false");
            });
            panes.forEach((pane) => {
                pane.hidden = pane.dataset.tabpane !== target;
            });
        });
    });

    // Pre-fill from existing settings.
    const current = loadSettings();
    if (zip) zip.value = current.zip ?? "";
    if (tz) tz.value = current.timezone ?? "";
    if (fmt) fmt.value = current.clockFormat ?? "";
    if (themeSelect) themeSelect.value = current.theme ?? "";

    form?.addEventListener("submit", (event) => {
        event.preventDefault();
        const next = {
            zip: zip?.value.trim() || undefined,
            timezone: tz?.value || undefined,
            clockFormat: (fmt?.value || undefined) as "12h" | "24h" | undefined,
            theme: (themeSelect?.value || undefined) as "light" | "dark" | undefined,
        };
        saveSettings(next);
        location.reload();
    });

    resetBtn?.addEventListener("click", () => {
        clearSettings();
        location.reload();
    });
</script>

<style>
    /* === Dialog window ===
       Authentic Win98 raised look: gray face + light highlight on top/left +
       dark shadow on bottom/right + 1px black outer border, all built from
       inset box-shadows so the title bar can span flush to the edges. */
    .settings-dialog {
        max-width: 560px;
        margin: 12px auto 24px;
        background: #c0c0c0;
        border: 1px solid #000000;
        box-shadow:
            inset 1px 1px 0 #ffffff,
            inset -1px -1px 0 #404040,
            inset 2px 2px 0 #dfdfdf,
            inset -2px -2px 0 #808080;
        padding: 3px;
    }

    .dialog-titlebar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 3px 4px 3px 8px;
        font: bold 13px Tahoma, sans-serif;
        color: #ffffff;
        background: linear-gradient(90deg, #000080, #1084d0);
    }

    .dialog-titlebar-text {
        flex: 1;
    }

    .dialog-close {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 20px;
        font: bold 13px Arial, sans-serif;
        line-height: 1;
        color: #000;
        text-decoration: none;
        background: #c0c0c0;
        border: 1px solid #000000;
        box-shadow:
            inset 1px 1px 0 #ffffff,
            inset -1px -1px 0 #404040;
    }

    .dialog-close:active {
        box-shadow:
            inset 1px 1px 0 #404040,
            inset -1px -1px 0 #ffffff;
    }

    .dialog-close:focus-visible {
        outline: 1px dotted #fff;
        outline-offset: -4px;
    }

    .dialog-body {
        padding: 10px 10px 8px;
    }

    /* === Tab strip ===
       Active tab overlaps the tab-pane border by 1px so they read as one. */
    .tab-strip {
        display: flex;
        padding-left: 6px;
        position: relative;
        z-index: 1;
    }

    /* Inactive tabs sit 2px lower with a slightly darker face. Active tab
       sits flush with the top and overlaps the pane's top border by 1px so
       it visually merges with the pane below. */
    .tab {
        padding: 4px 18px 5px;
        margin-top: 2px;
        margin-bottom: 0;
        font: 13px Tahoma, sans-serif;
        color: #000;
        background: #b8b4ad;
        border: 1px solid;
        border-top-color: #ffffff;
        border-left-color: #ffffff;
        border-right-color: #404040;
        border-bottom: 0;
        border-radius: 3px 3px 0 0;
        cursor: pointer;
    }

    .tab:focus-visible {
        outline: 1px dotted #000;
        outline-offset: -4px;
    }

    .tab--active {
        margin-top: 0;
        margin-bottom: -1px;
        padding-bottom: 6px;
        background: #c0c0c0;
        cursor: default;
    }

    .tab-pane {
        padding: 14px 14px 16px;
        background: #c0c0c0;
        border: 1px solid;
        border-top-color: #ffffff;
        border-left-color: #ffffff;
        border-right-color: #404040;
        border-bottom-color: #404040;
    }

    /* === Etched group boxes === */
    .groove {
        position: relative;
        margin: 0 0 14px;
        padding: 10px 14px 12px;
        border: 1px solid;
        border-top-color: #808080;
        border-left-color: #808080;
        border-right-color: #ffffff;
        border-bottom-color: #ffffff;
        background: transparent;
    }

    .groove legend {
        padding: 0 4px;
        font: 13px Tahoma, sans-serif;
    }

    .form-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 6px 0;
    }

    .form-row label {
        flex: 0 0 90px;
        font: 13px Tahoma, sans-serif;
    }

    /* === Inputs ===
       Sunken white field — light bottom/right + dark top/left + 1px outer
       gray for the printed "engraved" look. */
    .form-row input {
        flex: 1;
        max-width: 240px;
        height: 22px;
        padding: 2px 6px;
        font: 13px Tahoma, sans-serif;
        background: #ffffff;
        border: 1px solid;
        border-top-color: #404040;
        border-left-color: #404040;
        border-right-color: #ffffff;
        border-bottom-color: #ffffff;
        outline: 1px solid #808080;
        outline-offset: -2px;
    }

    .hint {
        margin: 6px 0 0 100px;
        font-size: 12px;
        color: #555;
    }

    /* === Chunky select with raised dropdown button ===
       Native arrow is hidden; ::after on the wrapper paints a Win98 button
       with a black triangle. Pointer events pass through to the select. */
    .select-wrap {
        position: relative;
        display: inline-flex;
        flex: 1;
        max-width: 240px;
        height: 22px;
        background: #ffffff;
        border: 1px solid;
        border-top-color: #404040;
        border-left-color: #404040;
        border-right-color: #ffffff;
        border-bottom-color: #ffffff;
        outline: 1px solid #808080;
        outline-offset: -2px;
    }

    .select-wrap select {
        appearance: none;
        -webkit-appearance: none;
        flex: 1;
        height: 100%;
        padding: 0 22px 0 6px;
        font: 13px Tahoma, sans-serif;
        background: transparent;
        border: 0;
        outline: 0;
        cursor: default;
    }

    /* The dropdown button sits over the right edge of the select. */
    .select-wrap::after {
        content: "";
        position: absolute;
        top: 1px;
        right: 1px;
        bottom: 1px;
        width: 18px;
        background: #c0c0c0;
        border: 1px solid;
        border-top-color: #ffffff;
        border-left-color: #ffffff;
        border-right-color: #404040;
        border-bottom-color: #404040;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 10 10'><polygon points='2,3 8,3 5,8' fill='black'/></svg>");
        background-repeat: no-repeat;
        background-position: center;
        pointer-events: none;
    }

    /* === Actions === */
    .dialog-actions {
        display: flex;
        justify-content: flex-end;
        gap: 6px;
        margin-top: 14px;
        padding-top: 12px;
        border-top: 1px solid #808080;
        box-shadow: 0 -1px 0 #ffffff;
    }

    .dialog-actions button {
        min-width: 80px;
        height: 24px;
        padding: 0 14px;
        font: 13px Tahoma, sans-serif;
        color: #000000;
        background: #c0c0c0;
        border: 1px solid #000000;
        box-shadow:
            inset 1px 1px 0 #ffffff,
            inset -1px -1px 0 #404040,
            inset 2px 2px 0 #dfdfdf,
            inset -2px -2px 0 #808080;
        cursor: pointer;
    }

    .dialog-actions button:active {
        box-shadow:
            inset 1px 1px 0 #404040,
            inset -1px -1px 0 #ffffff,
            inset 2px 2px 0 #808080,
            inset -2px -2px 0 #dfdfdf;
    }

    .dialog-actions button:focus {
        outline: 1px dotted #000;
        outline-offset: -4px;
    }
</style>
