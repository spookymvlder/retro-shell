---
import RetroShell from "../components/RetroShell.astro";
import { env } from "cloudflare:workers";
import { site } from "../site.config";

interface Entry {
    id: number;
    name: string;
    message: string;
    created_at: number;
}

const siteKey = env.PUBLIC_TURNSTILE_SITE_KEY ?? "";

let entries: Entry[] = [];
let loadError: string | null = null;

if (site.guestbook.enabled) {
    try {
        const result = await env.DB.prepare(
            "SELECT id, name, message, created_at FROM entries ORDER BY created_at DESC LIMIT ?",
        )
            .bind(site.guestbook.entriesPerPage)
            .all<Entry>();
        entries = result.results ?? [];
    } catch (err) {
        loadError = "Could not load guestbook entries.";
        console.error(err);
    }
}

function formatDate(unix: number): string {
    return new Date(unix * 1000).toLocaleString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
        hour: "2-digit",
        minute: "2-digit",
    });
}
---

<RetroShell title="Guestbook">
    <h1>Guestbook</h1>
    <p>Sign the book! Your message will appear below after you submit.</p>

    {site.guestbook.enabled ? (
        <form method="POST" action="/api/guestbook" class="gb-form">
            <label>
                <span>Name</span>
                <input name="name" maxlength={site.guestbook.maxNameLength} required />
            </label>
            <label>
                <span>Message</span>
                <textarea name="message" rows="4" maxlength={site.guestbook.maxMessageLength} required></textarea>
            </label>
            <div class="cf-turnstile" data-sitekey={siteKey}></div>
            <button type="submit">Sign the book</button>
        </form>
    ) : (
        <p><em>The guestbook is currently closed.</em></p>
    )}

    <hr />

    {loadError && <p class="gb-error">{loadError}</p>}

    {entries.length === 0 && !loadError ? (
        <p><em>No entries yet — be the first!</em></p>
    ) : (
        <ul class="gb-entries">
            {entries.map((entry) => (
                <li class="gb-entry">
                    <div class="gb-meta">
                        <strong>{entry.name}</strong>
                        <span class="gb-date">{formatDate(entry.created_at)}</span>
                    </div>
                    <p class="gb-message">{entry.message}</p>
                </li>
            ))}
        </ul>
    )}

    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</RetroShell>

<style>
    .gb-form {
        display: flex;
        flex-direction: column;
        gap: 12px;
        max-width: 560px;
        padding: 14px;
        /* Beige Win98 panel — stays beige in both themes since it's chrome,
           not page content. Force dark text so labels stay readable when the
           page theme flips. */
        color: #111;
        background: #ece9d8;
        border: 2px solid #fff;
        border-right-color: #555;
        border-bottom-color: #555;
    }

    .gb-form label {
        display: flex;
        flex-direction: column;
        gap: 4px;
        font-size: 16px;
    }

    .gb-form input,
    .gb-form textarea {
        padding: 4px 6px;
        font: 16px Tahoma, sans-serif;
        background: white;
        border: 2px inset #d4d0c8;
    }

    .gb-form button {
        align-self: flex-start;
        height: 34px;
        padding: 0 16px;
        font: 18px Tahoma, sans-serif;
        background: #ece9d8;
        border: 2px solid #fff;
        border-right-color: #555;
        border-bottom-color: #555;
        cursor: pointer;
    }

    .gb-form input:focus-visible,
    .gb-form textarea:focus-visible {
        outline: 2px solid var(--page-accent);
        outline-offset: 1px;
    }

    .gb-form button:focus-visible {
        outline: 2px dotted var(--page-accent);
        outline-offset: -4px;
    }

    .gb-entries {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .gb-entry {
        padding: 10px 14px;
        background: var(--page-card-bg);
        border: 1px solid var(--page-muted);
    }

    .gb-meta {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 6px;
        font-size: 16px;
    }

    .gb-date {
        color: #555;
    }

    .gb-message {
        margin: 0;
        white-space: pre-wrap;
        word-wrap: break-word;
    }

    .gb-error {
        color: #a00;
    }
</style>
