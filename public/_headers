# Cloudflare Workers Static Assets headers file.
# Workers reads this directly when serving from the assets binding.
# Files in public/ are copied to dist/client/ at build time.
#
# Edit cautiously — over-strict CSP will break Turnstile, Pagefind, or
# Astro's inlined scripts/styles.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; frame-src https://challenges.cloudflare.com; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'
